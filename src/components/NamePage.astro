---
import Layout from '../layouts/Layout.astro';
import MapSardegna from './MapSardegna.astro';
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = langPrefix(lang);

function pathFor(key: keyof typeof pageSlugs): string {
  const slug = pageSlugs[key][lang];
  if (!slug) return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}/${slug}/`;
}

const communes = [
  { nom: 'Villaputzu', prov: { fr: 'Sud Sardaigne', it: 'Sud Sardegna', en: 'South Sardinia' }, p: true },
  { nom: 'Lula', prov: { fr: 'Nuoro', it: 'Nuoro', en: 'Nuoro' } },
  { nom: 'Ghilarza', prov: { fr: 'Oristano', it: 'Oristano', en: 'Oristano' } },
  { nom: 'San Vito', prov: { fr: 'Sud Sardaigne', it: 'Sud Sardegna', en: 'South Sardinia' } },
  { nom: 'Nuoro', prov: { fr: 'Nuoro', it: 'Nuoro', en: 'Nuoro' } },
  { nom: 'Buddusò', prov: { fr: 'Sassari', it: 'Sassari', en: 'Sassari' } },
  { nom: 'Samassi', prov: { fr: 'Sud Sardaigne', it: 'Sud Sardegna', en: 'South Sardinia' } },
  { nom: 'Montresta', prov: { fr: 'Oristano', it: 'Oristano', en: 'Oristano' } },
  { nom: 'Sarule', prov: { fr: 'Nuoro', it: 'Nuoro', en: 'Nuoro' } },
];
---

<Layout title={t.name.metaTitle} lang={lang} pageKey="name">

  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16 border-b border-sardaigne-encre/15">
    <div class="grid lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-2 font-display italic text-7xl text-sardaigne-rouge">II</div>
      <div class="lg:col-span-10">
        <div class="eyebrow">{t.ui.chapter} {t.ui.chapters[1]}</div>
        <h1 class="font-display text-5xl md:text-7xl mt-3 leading-[0.95] text-sardaigne-encre">
          {t.name.chapterTitle.split(' ')[0]} <em class="text-sardaigne-rouge">{t.name.chapterTitle.split(' ').slice(1).join(' ')}</em>
        </h1>
        <p class="font-serif text-xl mt-6 text-sardaigne-encre/80 italic max-w-3xl">
          {t.name.chapterSub}
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-12 gap-12">
    <div class="lg:col-span-5">
      <div class="eyebrow">{t.name.etymologyEyebrow}</div>
      <h2 class="font-display text-4xl md:text-5xl mt-3 text-sardaigne-encre leading-tight">
        {t.name.etymologyTitle1}<br/>
        <em class="text-sardaigne-rouge">{t.name.etymologyTitle2}</em>
      </h2>
    </div>
    <div class="lg:col-span-7 font-serif text-lg leading-relaxed space-y-5 text-sardaigne-encre/90">
      <p class="drop-cap">{t.name.etymologyP1}</p>
      <p>{t.name.etymologyP2}</p>
      <p>{t.name.etymologyP3}</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-12">
    <div class="bg-sardaigne-encre text-sardaigne-parchemin p-10 md:p-16 grid md:grid-cols-2 gap-10">
      <div>
        <div class="eyebrow text-sardaigne-parchemin/70">{t.name.dictEyebrow}</div>
        <div class="font-display italic text-sardaigne-rouge mt-4 break-words" style="font-size:clamp(4rem,9vw,8rem);line-height:0.95;">porcu</div>
        <div class="font-serif text-pierre-100 mt-3 text-lg">
          <em>{t.name.dictGloss}</em>
        </div>
      </div>
      <div class="font-serif space-y-4 text-pierre-100 leading-relaxed">
        <div>
          <span class="font-sans text-xs tracking-widest uppercase text-pierre-300">1.</span>
          {t.name.dictDef1}
        </div>
        <div>
          <span class="font-sans text-xs tracking-widest uppercase text-pierre-300">2.</span>
          {t.name.dictDef2}
        </div>
        <div class="pt-4 border-t border-pierre-700 text-sm italic">
          {t.name.dictEtym}
        </div>
      </div>
    </div>
  </section>

  <section id="cartographie" class="max-w-7xl mx-auto px-6 py-20">
    <div class="mb-12 max-w-3xl">
      <div class="eyebrow">{t.name.cartoEyebrow}</div>
      <h2 class="font-display text-4xl md:text-5xl mt-3 text-sardaigne-encre leading-tight">
        {t.name.cartoTitle1} <em class="text-sardaigne-rouge">{t.name.cartoTitle2}</em>
      </h2>
      <p class="font-serif text-lg mt-5 text-sardaigne-encre/85 leading-relaxed">
        {t.name.cartoLead}
      </p>
    </div>
    <MapSardegna lang={lang} />
  </section>

  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="mb-10">
      <div class="eyebrow">{t.name.indexEyebrow}</div>
      <h2 class="font-display text-3xl md:text-4xl mt-3 text-sardaigne-encre">
        {t.name.indexTitle}
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-[1px] bg-sardaigne-encre/15">
      {communes.map((c, i) => (
        <div class="bg-sardaigne-parchemin p-7 flex flex-col justify-between min-h-[180px] group hover:bg-pierre-50 transition-colors">
          <div>
            <span class="font-mono text-xs text-sardaigne-sepia">№ {String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display text-3xl text-sardaigne-encre mt-2 flex items-center gap-3">
              {c.nom}
              {c.p && <span class="text-sardaigne-rouge text-xl">✦</span>}
            </h3>
          </div>
          <div class="eyebrow text-sardaigne-sepia mt-6">{c.prov[lang]}</div>
        </div>
      ))}
    </div>
  </section>

  <section id="diaspora" class="bg-sardaigne-encre text-sardaigne-parchemin py-24">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <div class="eyebrow text-sardaigne-parchemin/70">{t.name.diasporaSectionEyebrow}</div>
        <h2 class="font-display text-4xl md:text-6xl mt-4 text-sardaigne-parchemin leading-[0.95]">
          {t.name.diasporaSectionTitle1}<br/>
          <em class="text-sardaigne-rouge">{t.name.diasporaSectionTitle2}</em>
        </h2>
      </div>
      <div class="lg:col-span-7 font-serif text-lg leading-relaxed space-y-5 text-pierre-100">
        <p>{t.name.diasporaSectionP1}</p>
        <p>{t.name.diasporaSectionP2}</p>
        <p>{t.name.diasporaSectionP3}</p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20 text-center">
    <div class="ornament">✦</div>
    <p class="font-display italic text-2xl md:text-3xl mt-10 text-sardaigne-encre/80">
      {t.name.transitionQuote}
    </p>
    <a href={pathFor('sardinia')} class="inline-flex items-center gap-3 mt-10 font-sans text-sm tracking-widest uppercase text-sardaigne-encre hover:text-sardaigne-rouge transition-colors border-b border-sardaigne-encre hover:border-sardaigne-rouge pb-1">
      {t.name.transitionLink}
      <span>→</span>
    </a>
  </section>

</Layout>
