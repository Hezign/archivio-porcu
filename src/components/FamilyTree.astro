---
import { arbre } from '../data/arbre';
import { useTranslations } from '../i18n';
import type { Lang } from '../i18n/config';

export interface Props { lang?: Lang; }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const tt = t.genealogy.tree;
---

<div class="bg-sardaigne-parchemin border border-sardaigne-encre/20 p-6 md:p-10 topo-lines">

  <div class="text-center mb-10">
    <div class="eyebrow">{tt.eyebrow}</div>
    <h3 class="font-display text-3xl md:text-4xl text-sardaigne-encre mt-2">{tt.title}</h3>
    <p class="font-serif text-sm text-sardaigne-encre/70 italic mt-3 max-w-xl mx-auto">
      {tt.sub}
    </p>
  </div>

  <div class="max-w-3xl mx-auto">
    {arbre.map((personne, i) => (
      <div class="relative pb-8">
        {i < arbre.length - 1 && (
          <div class="absolute left-1/2 top-full h-8 w-[1px] bg-sardaigne-sepia/40"></div>
        )}

        <div class={`relative bg-sardaigne-parchemin border-2 p-6 transition-all ${personne.verifie ? 'border-sardaigne-rouge' : 'border-dashed border-sardaigne-sepia/50'}`}>
          <div class="flex items-start justify-between">
            <div>
              <div class="eyebrow text-sardaigne-sepia">{tt.generation} {i + 1}</div>
              <div class="font-display text-2xl text-sardaigne-encre mt-1">
                {personne.prenom} <span class="font-semibold">{personne.nom}</span>
              </div>
            </div>
            <div class={`text-[0.65rem] font-mono tracking-widest uppercase px-2 py-1 ${personne.verifie ? 'bg-sardaigne-rouge text-sardaigne-parchemin' : 'bg-pierre-100 text-sardaigne-sepia border border-sardaigne-sepia/30'}`}>
              {personne.verifie ? tt.verified : tt.toDocument}
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4 mt-4 font-serif text-sm">
            <div>
              <div class="font-sans text-[0.65rem] tracking-widest uppercase text-sardaigne-sepia mb-1">{tt.birth}</div>
              <div class="text-sardaigne-encre/80">
                {personne.naissance?.annee || '?'}<br/>
                <span class="italic text-sardaigne-encre/60">{personne.naissance?.lieu || '—'}</span>
              </div>
            </div>
            <div>
              <div class="font-sans text-[0.65rem] tracking-widest uppercase text-sardaigne-sepia mb-1">{tt.death}</div>
              <div class="text-sardaigne-encre/80">
                {personne.deces?.annee || '—'}<br/>
                <span class="italic text-sardaigne-encre/60">{personne.deces?.lieu || ''}</span>
              </div>
            </div>
          </div>

          {personne.notes && (
            <div class="mt-4 pt-4 border-t border-sardaigne-sepia/20 font-serif text-[0.9rem] italic text-sardaigne-encre/75">
              « {personne.notes} »
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="mt-10 max-w-3xl mx-auto bg-sardaigne-encre text-sardaigne-parchemin p-6 md:p-8 border-l-4 border-sardaigne-rouge">
    <div class="eyebrow text-sardaigne-parchemin/70">{tt.goldenRuleEyebrow}</div>
    <p class="font-display text-xl md:text-2xl leading-snug mt-2">
      {tt.goldenRule1}<br/>
      <span class="text-sardaigne-rouge">{tt.goldenRule2}</span>
    </p>
    <p class="font-serif text-sm text-pierre-200 italic mt-3">
      {tt.goldenRuleSub}
    </p>
  </div>

</div>
