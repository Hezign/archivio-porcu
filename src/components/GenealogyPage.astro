---
import Layout from '../layouts/Layout.astro';
import FamilyTree from './FamilyTree.astro';
import ContribForm from './ContribForm.astro';
import LegalNotice from './LegalNotice.astro';
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = langPrefix(lang);

function pathFor(key: keyof typeof pageSlugs): string {
  const slug = pageSlugs[key][lang];
  if (!slug) return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}/${slug}/`;
}
---

<Layout title={t.genealogy.metaTitle} lang={lang} pageKey="genealogy">

  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16 border-b border-sardaigne-encre/15">
    <div class="grid lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-2 font-display italic text-7xl text-sardaigne-rouge">VI</div>
      <div class="lg:col-span-10">
        <div class="eyebrow">{t.genealogy.chapterTitleSub}</div>
        <h1 class="font-display text-5xl md:text-7xl mt-3 leading-[0.95] text-sardaigne-encre">
          <em class="text-sardaigne-rouge">{t.genealogy.chapterTitle1}</em><br/>
          {t.genealogy.chapterTitle2}
        </h1>
        <p class="font-serif text-xl mt-6 text-sardaigne-encre/80 italic max-w-3xl">
          {t.genealogy.chapterSub}
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20">
    <p class="font-serif text-xl md:text-2xl leading-relaxed text-sardaigne-encre/90 drop-cap">
      {t.genealogy.intro}
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-8">
    <LegalNotice variant="genealogie" lang={lang} />
  </section>

  <section class="max-w-7xl mx-auto px-6 py-10">
    <FamilyTree lang={lang} />
  </section>

  <section id="methode" class="max-w-7xl mx-auto px-6 py-24">
    <div class="max-w-3xl mb-16">
      <div class="eyebrow">{t.genealogy.methodEyebrow}</div>
      <h2 class="font-display text-5xl md:text-6xl mt-3 text-sardaigne-encre leading-[0.95]">
        {t.genealogy.methodTitle1}<br/>
        {t.genealogy.methodTitle2} <em class="text-sardaigne-rouge">{t.genealogy.methodTitle3}</em>
      </h2>
      <p class="font-serif text-lg mt-5 text-sardaigne-encre/80 leading-relaxed">
        {t.genealogy.methodLead}
      </p>
    </div>

    <div class="space-y-[1px] bg-sardaigne-encre/15">
      {t.genealogy.methodSteps.map(step => (
        <div class="bg-sardaigne-parchemin p-8 md:p-10 grid md:grid-cols-[140px_1fr] gap-6 md:gap-10 items-start">
          <div class="font-display text-6xl md:text-7xl italic text-sardaigne-rouge leading-none">
            {step.num}
          </div>
          <div>
            <h3 class="font-display text-2xl md:text-3xl text-sardaigne-encre leading-tight">{step.titre}</h3>
            <p class="font-serif text-[1.05rem] mt-4 leading-relaxed text-sardaigne-encre/85">{step.texte}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-sardaigne-encre text-sardaigne-parchemin py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-10 mb-16">
        <div class="lg:col-span-5">
          <div class="eyebrow text-sardaigne-parchemin/70">{t.genealogy.archivesEyebrow}</div>
          <h2 class="font-display text-5xl md:text-6xl mt-4 text-sardaigne-parchemin leading-[0.95]">
            {t.genealogy.archivesTitle1} <em class="text-sardaigne-rouge">{t.genealogy.archivesTitle2}</em> {t.genealogy.archivesTitle3}
          </h2>
        </div>
        <div class="lg:col-span-7 flex items-end">
          <p class="font-serif text-lg text-pierre-100 leading-relaxed">
            {t.genealogy.archivesLead}
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-[1px] bg-pierre-800">
        {t.genealogy.archives.map(r => (
          <div class="bg-sardaigne-encre p-8">
            <div class="font-display text-2xl text-sardaigne-parchemin">{r.nom}</div>
            <div class="font-sans text-[0.7rem] tracking-widest uppercase text-sardaigne-parchemin/60 mt-1">{r.org}</div>
            <p class="font-serif text-sm text-pierre-200 mt-4 leading-relaxed">{r.desc}</p>
            <div class="mt-5 pt-4 border-t border-pierre-700/60">
              <span class="inline-block font-mono text-[0.65rem] tracking-widest text-sardaigne-rouge">{r.cat}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="contribuer" class="max-w-7xl mx-auto px-6 py-24">
    <ContribForm lang={lang} />
  </section>

  <section class="max-w-4xl mx-auto px-6 py-24">
    <div class="border-y-2 border-sardaigne-encre py-16 text-center">
      <div class="ornament">✦</div>
      <p class="font-display text-2xl md:text-4xl leading-tight mt-10 text-sardaigne-encre italic">
        {t.genealogy.ethicalQuote}
      </p>
      <p class="font-sans text-xs tracking-widest uppercase text-sardaigne-sepia mt-10">
        {t.genealogy.ethicalSub}
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20 text-center">
    <p class="font-display italic text-2xl md:text-3xl text-sardaigne-encre/80">
      {t.genealogy.closing}
    </p>
    <a href={pathFor('home')} class="inline-flex items-center gap-3 mt-10 font-sans text-sm tracking-widest uppercase text-sardaigne-encre hover:text-sardaigne-rouge transition-colors border-b border-sardaigne-encre hover:border-sardaigne-rouge pb-1">
      {t.ui.backHome}
    </a>
  </section>

</Layout>
