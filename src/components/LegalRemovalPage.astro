---
import Layout from '../layouts/Layout.astro';
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const r = t.legal.removal;
const prefix = langPrefix(lang);

function pathFor(key: keyof typeof pageSlugs): string {
  const slug = pageSlugs[key][lang];
  if (!slug) return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}/${slug}/`;
}
---

<Layout title={r.metaTitle} lang={lang} pageKey="legalRemoval">

  <section class="max-w-3xl mx-auto px-6 pt-24 pb-16 border-b border-sardaigne-encre/15">
    <div class="eyebrow">{r.eyebrow}</div>
    <h1 class="font-display text-5xl md:text-6xl mt-4 text-sardaigne-encre leading-[0.95]">
      {r.title1} <em class="text-sardaigne-rouge">{r.title2}</em>
    </h1>
    <p class="font-serif text-lg mt-6 text-sardaigne-encre/80 italic">{r.sub}</p>
  </section>

  <section class="max-w-3xl mx-auto px-6 py-16">
    <p class="font-serif text-lg leading-relaxed text-sardaigne-encre/90 drop-cap">
      {r.intro}
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16">
    <div class="bg-sardaigne-encre text-sardaigne-parchemin p-8 md:p-12">
      <div class="eyebrow text-sardaigne-parchemin/70">{r.formEyebrow}</div>
      <h2 class="font-display text-3xl md:text-4xl text-sardaigne-parchemin mt-3">{r.formTitle}</h2>

      <form id="removal-form" class="mt-10 space-y-6" action="#" method="POST" data-confirm={r.confirm}>

        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label class="block eyebrow text-pierre-300 mb-2">{r.firstName}</label>
            <input type="text" name="prenom" required
              class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg" />
          </div>
          <div>
            <label class="block eyebrow text-pierre-300 mb-2">{r.lastName}</label>
            <input type="text" name="nom" required
              class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg" />
          </div>
        </div>

        <div>
          <label class="block eyebrow text-pierre-300 mb-2">{r.email}</label>
          <input type="email" name="email" required
            class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg" />
        </div>

        <div>
          <label class="block eyebrow text-pierre-300 mb-2">{r.type}</label>
          <select name="type"
            class="w-full bg-sardaigne-encre border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg">
            {r.types.map(t => <option>{t}</option>)}
          </select>
        </div>

        <div>
          <label class="block eyebrow text-pierre-300 mb-2">{r.pageUrl}</label>
          <input type="text" name="url" placeholder={r.pageUrlPlaceholder}
            class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg" />
        </div>

        <div>
          <label class="block eyebrow text-pierre-300 mb-2">{r.details}</label>
          <textarea name="details" rows="6" required placeholder={r.detailsPlaceholder}
            class="w-full bg-transparent border border-pierre-400/30 focus:border-sardaigne-rouge outline-none p-3 text-sardaigne-parchemin font-serif resize-none"></textarea>
        </div>

        <div class="bg-sardaigne-encre/50 border border-pierre-400/20 p-5">
          <div class="eyebrow text-pierre-300 mb-2">{r.proof}</div>
          <p class="font-sans text-xs text-pierre-200 leading-relaxed">{r.proofText}</p>
        </div>

        <button type="submit"
          class="group inline-flex items-center gap-3 bg-sardaigne-rouge hover:bg-sardaigne-rouge-sombre text-sardaigne-parchemin px-8 py-4 font-sans text-sm tracking-widest uppercase transition-colors">
          <span>{r.submit}</span>
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </button>

      </form>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-20">
    <div class="border border-sardaigne-encre/20 p-6">
      <div class="eyebrow">{r.altEyebrow}</div>
      <h3 class="font-display text-xl mt-2 text-sardaigne-encre">{r.altTitle}</h3>
      <p class="font-serif text-[0.95rem] mt-3 text-sardaigne-encre/85 leading-relaxed">{r.altText}</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-4 text-sm font-sans">
      <a href={pathFor('legalMentions')} class="block p-5 border border-sardaigne-encre/20 hover:bg-sardaigne-encre hover:text-sardaigne-parchemin transition-colors">
        <div class="eyebrow mb-2">{t.legal.mentions.navBack}</div>
        {t.ui.legalLinks.mentions} →
      </a>
      <a href={pathFor('legalPrivacy')} class="block p-5 border border-sardaigne-encre/20 hover:bg-sardaigne-encre hover:text-sardaigne-parchemin transition-colors">
        <div class="eyebrow mb-2">{t.legal.mentions.navNext}</div>
        {t.ui.legalLinks.privacy} →
      </a>
    </div>
  </section>

  <script>
    const form = document.getElementById('removal-form') as HTMLFormElement | null;
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const msg = form.dataset.confirm || 'Merci !';
      alert(msg);
    });
  </script>

</Layout>
