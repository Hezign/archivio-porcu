---
import { communes } from '../data/communes';

// Bounding box Sardaigne (approximatif, avec marge)
const minLat = 38.85;
const maxLat = 41.30;
const minLng = 8.10;
const maxLng = 9.85;

const W = 600;
const H = 800;

function project(lat: number, lng: number) {
  const x = ((lng - minLng) / (maxLng - minLng)) * W;
  const y = H - ((lat - minLat) / (maxLat - minLat)) * H;
  return { x, y };
}

const points = communes.map(c => ({
  ...c,
  ...project(c.lat, c.lng),
}));
---

<div class="relative bg-sardaigne-parchemin border border-sardaigne-encre/20 p-4 md:p-8">

  <!-- En-tête carte style vieille cartographie -->
  <div class="flex items-start justify-between mb-6 pb-4 border-b border-sardaigne-sepia/30">
    <div>
      <div class="eyebrow">Tabula Sardiniae</div>
      <h3 class="font-display text-2xl md:text-3xl text-sardaigne-encre mt-1">Attestation du patronyme</h3>
    </div>
    <div class="text-right hidden sm:block">
      <div class="font-mono text-xs text-sardaigne-sepia">N</div>
      <div class="w-8 h-8 border border-sardaigne-sepia flex items-center justify-center mx-auto my-1">
        <span class="font-display text-sardaigne-rouge">↑</span>
      </div>
      <div class="font-mono text-[0.6rem] text-sardaigne-sepia">Échelle approx.</div>
    </div>
  </div>

  <div class="grid md:grid-cols-[1fr_320px] gap-6">

    <!-- Carte SVG -->
    <div class="relative topo-lines bg-sardaigne-parchemin/50">
      <svg
        viewBox={`0 0 ${W} ${H}`}
        class="w-full h-auto max-h-[600px]"
        preserveAspectRatio="xMidYMid meet"
      >
        <!-- Silhouette Sardaigne (simplifiée, stylisée) -->
        <defs>
          <pattern id="hatch" patternUnits="userSpaceOnUse" width="4" height="4" patternTransform="rotate(45)">
            <line x1="0" y1="0" x2="0" y2="4" stroke="#8a6a3e" stroke-width="0.5" opacity="0.3"/>
          </pattern>
          <filter id="paper">
            <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2"/>
            <feColorMatrix values="0 0 0 0 0.54  0 0 0 0 0.42  0 0 0 0 0.24  0 0 0 0.15 0"/>
            <feComposite in2="SourceGraphic" operator="in"/>
          </filter>
        </defs>

        <!-- Silhouette Sardaigne — basée sur les coordonnées géographiques réelles
             (Capo Testa, Capo Caccia, Capo Spartivento, Capo Carbonara, etc.) -->
        <path
          d="M 356.6 14.7 L 365.1 20.4 Q 373.7 26.1 390.9 37.5 Q 408.0 49.0 437.1 51.5 Q 466.3 53.9 474.9 58.0 Q 483.4 62.0 491.1 83.2 Q 498.9 104.5 510.9 120.8 Q 522.9 137.1 539.1 153.4 Q 555.4 169.8 567.4 195.9 Q 579.4 222.0 569.1 261.2 Q 558.9 300.4 556.3 349.4 Q 553.7 398.4 545.2 431.0 Q 536.6 463.7 532.3 493.0 Q 528.0 522.4 524.5 555.1 Q 521.1 587.8 517.7 604.1 Q 514.3 620.4 507.4 644.9 Q 500.6 669.4 498.9 689.0 Q 497.1 708.6 450.9 716.8 Q 404.6 724.9 382.3 734.7 Q 360.0 744.5 330.9 754.3 Q 301.7 764.1 284.5 772.2 Q 267.4 780.4 229.7 785.3 Q 192.0 790.2 169.7 779.6 Q 147.4 769.0 128.6 747.8 Q 109.7 726.5 102.8 701.2 Q 96.0 675.9 98.5 644.9 Q 101.1 613.9 105.4 581.2 Q 109.7 548.6 109.7 521.6 Q 109.7 494.7 111.4 477.5 Q 113.1 460.4 114.8 452.2 Q 116.6 444.1 106.3 419.6 Q 96.0 395.1 84.8 373.9 Q 73.7 352.7 76.3 320.0 Q 78.9 287.3 81.5 261.2 Q 84.0 235.1 90.0 215.5 Q 96.0 195.9 80.5 173.9 Q 65.1 151.8 46.2 139.6 Q 27.4 127.3 34.2 115.1 Q 41.1 102.9 69.4 93.1 Q 97.7 83.3 107.2 77.5 Q 116.6 71.8 136.3 66.9 Q 156.0 62.0 191.2 55.5 Q 226.3 49.0 245.2 55.5 Q 264.0 62.0 286.3 57.1 Q 308.6 52.2 317.1 49.8 Q 325.7 47.3 334.3 41.6 Q 342.9 35.9 349.8 25.3 L 356.6 14.7 Z"
          fill="url(#hatch)"
          stroke="#1f1a14"
          stroke-width="1.5"
          stroke-linejoin="round"
          opacity="0.95"
        />

        <!-- Îles satellites principales -->
        <!-- Asinara (NO) -->
        <ellipse cx="50" cy="65" rx="6" ry="14" fill="url(#hatch)" stroke="#1f1a14" stroke-width="1" opacity="0.95"/>
        <!-- La Maddalena (NE) -->
        <circle cx="500" cy="40" r="4" fill="url(#hatch)" stroke="#1f1a14" stroke-width="1" opacity="0.95"/>
        <circle cx="510" cy="48" r="3" fill="url(#hatch)" stroke="#1f1a14" stroke-width="1" opacity="0.95"/>
        <!-- Tavolara (E) -->
        <ellipse cx="555" cy="220" rx="5" ry="3" fill="url(#hatch)" stroke="#1f1a14" stroke-width="1" opacity="0.95"/>
        <!-- Sant'Antioco (SO) -->
        <path d="M 80 660 Q 90 655 95 670 Q 92 690 78 685 Q 70 678 80 660 Z" fill="url(#hatch)" stroke="#1f1a14" stroke-width="1" opacity="0.95"/>
        <!-- San Pietro (SO) -->
        <ellipse cx="62" cy="650" rx="6" ry="5" fill="url(#hatch)" stroke="#1f1a14" stroke-width="1" opacity="0.95"/>

        <!-- Relief — Barbagia / Supramonte (zone centre-est, autour de Nuoro) -->
        <g opacity="0.4" stroke="#8a6a3e" fill="none" stroke-width="0.6">
          <ellipse cx="400" cy="340" rx="65" ry="40" />
          <ellipse cx="400" cy="340" rx="50" ry="30" />
          <ellipse cx="400" cy="340" rx="35" ry="20" />
          <ellipse cx="400" cy="340" rx="22" ry="12" />
          <text x="400" y="295" text-anchor="middle" font-family="EB Garamond" font-size="11" fill="#8a6a3e" font-style="italic" opacity="0.9">Barbagia</text>
        </g>

        <!-- Légende régionale (positions ajustées sur la silhouette précise) -->
        <text x="430" y="100" font-family="EB Garamond" font-size="10" fill="#8a6a3e" font-style="italic" opacity="0.7">Gallura</text>
        <text x="280" y="640" font-family="EB Garamond" font-size="10" fill="#8a6a3e" font-style="italic" opacity="0.7">Campidano</text>
        <text x="190" y="430" font-family="EB Garamond" font-size="10" fill="#8a6a3e" font-style="italic" opacity="0.7">Oristano</text>
        <text x="220" y="200" font-family="EB Garamond" font-size="10" fill="#8a6a3e" font-style="italic" opacity="0.7">Sassarese</text>
        <text x="500" y="500" font-family="EB Garamond" font-size="10" fill="#8a6a3e" font-style="italic" opacity="0.7">Ogliastra</text>

        <!-- Communes -->
        {points.map((c, i) => (
          <g class="commune-marker cursor-pointer" data-id={c.nom}>
            <circle
              cx={c.x}
              cy={c.y}
              r={c.priorite ? 8 : 5}
              fill="#9a1b1f"
              stroke="#f1e8d4"
              stroke-width="1.5"
              opacity={c.priorite ? 1 : 0.85}
            />
            {c.priorite && (
              <circle
                cx={c.x}
                cy={c.y}
                r="14"
                fill="none"
                stroke="#9a1b1f"
                stroke-width="1"
                opacity="0.5"
                class="pulse-ring"
              />
            )}
            <text
              x={c.x + (c.priorite ? 14 : 10)}
              y={c.y + 4}
              font-family="Cormorant Garamond"
              font-size={c.priorite ? 15 : 13}
              font-weight={c.priorite ? 600 : 500}
              fill="#1f1a14"
            >{c.nom}</text>
          </g>
        ))}

        <!-- Rose des vents discrète -->
        <g transform="translate(520, 720)" opacity="0.5">
          <circle r="25" fill="none" stroke="#8a6a3e" stroke-width="0.5"/>
          <line x1="0" y1="-25" x2="0" y2="25" stroke="#8a6a3e" stroke-width="0.5"/>
          <line x1="-25" y1="0" x2="25" y2="0" stroke="#8a6a3e" stroke-width="0.5"/>
          <polygon points="0,-25 4,0 0,25 -4,0" fill="#9a1b1f" opacity="0.7"/>
          <text x="0" y="-30" text-anchor="middle" font-family="EB Garamond" font-size="8" fill="#8a6a3e">N</text>
        </g>
      </svg>
    </div>

    <!-- Détail commune -->
    <div id="commune-details" class="bg-sardaigne-encre text-sardaigne-parchemin p-6 min-h-[400px] flex flex-col">
      <div class="eyebrow text-sardaigne-parchemin/70">Commune sélectionnée</div>
      <h4 id="commune-name" class="font-display text-3xl mt-2 text-sardaigne-parchemin">Villaputzu</h4>
      <div id="commune-province" class="font-sans text-xs tracking-wider uppercase text-pierre-300 mt-1">Sud Sardaigne</div>
      <div class="rule my-4 opacity-40"></div>
      <p id="commune-notes" class="font-serif text-[0.95rem] leading-relaxed text-pierre-100">
        Commune côtière de l'Ogliastra méridionale. Forte concentration historique du patronyme Porcu dans les registres paroissiaux du XVIIIᵉ siècle.
      </p>
      <div class="mt-auto pt-6 text-[0.7rem] font-mono text-pierre-300 flex justify-between border-t border-pierre-700">
        <span id="commune-coords">39.44° N · 9.57° E</span>
        <span class="text-sardaigne-rouge">✦ priorité</span>
      </div>
    </div>
  </div>

  <!-- Légende -->
  <div class="mt-6 pt-4 border-t border-sardaigne-sepia/20 flex flex-wrap gap-5 items-center text-xs font-sans text-sardaigne-encre/70">
    <span class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-sardaigne-rouge ring-2 ring-sardaigne-rouge/30 ring-offset-1 ring-offset-sardaigne-parchemin"></span>
      Commune prioritaire
    </span>
    <span class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-sardaigne-rouge/85"></span>
      Attestation historique
    </span>
    <span class="italic text-sardaigne-sepia">Cliquez sur un point pour en savoir plus</span>
  </div>

</div>

<style>
  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.4); opacity: 0; }
  }
  .pulse-ring {
    transform-origin: center;
    transform-box: fill-box;
    animation: pulse-scale 2.2s ease-in-out infinite;
  }
  .commune-marker:hover circle:first-of-type {
    r: 10;
    transition: all 0.2s ease;
  }
</style>

<script define:vars={{ communesData: communes }}>
  const details = {
    name: document.getElementById('commune-name'),
    province: document.getElementById('commune-province'),
    notes: document.getElementById('commune-notes'),
    coords: document.getElementById('commune-coords'),
  };

  document.querySelectorAll('.commune-marker').forEach(marker => {
    marker.addEventListener('click', () => {
      const id = marker.getAttribute('data-id');
      const c = communesData.find(x => x.nom === id);
      if (!c) return;
      details.name.textContent = c.nom;
      details.province.textContent = c.province;
      details.notes.textContent = c.notes;
      details.coords.textContent = `${c.lat.toFixed(2)}° N · ${c.lng.toFixed(2)}° E`;
    });
  });
</script>
