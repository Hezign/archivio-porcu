---
import { communes } from '../data/communes';
import { useTranslations } from '../i18n';
import type { Lang } from '../i18n/config';

export interface Props {
  lang?: Lang;
}
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);

// Image dimensions
const W = 960;
const H = 1759;

// Bounding box géographique
const minLat = 38.83;
const maxLat = 41.27;
const minLng = 8.13;
const maxLng = 9.84;

function project(lat: number, lng: number) {
  const marginLeft = 0.06;
  const marginRight = 0.06;
  const marginTop = 0.03;
  const marginBottom = 0.03;
  const usableW = W * (1 - marginLeft - marginRight);
  const usableH = H * (1 - marginTop - marginBottom);
  const x = W * marginLeft + ((lng - minLng) / (maxLng - minLng)) * usableW;
  const y = H * marginTop + (1 - (lat - minLat) / (maxLat - minLat)) * usableH;
  return { x, y };
}

const labelOffsets: Record<string, { dx: number; dy: number; anchor: 'start' | 'end' }> = {
  'Villaputzu':  { dx: 28,  dy: 16,  anchor: 'start' },
  'San Vito':    { dx: -28, dy: -8,  anchor: 'end' },
  'Lula':        { dx: 28,  dy: 8,   anchor: 'start' },
  'Ghilarza':    { dx: -28, dy: 8,   anchor: 'end' },
  'Nuoro':       { dx: 28,  dy: 8,   anchor: 'start' },
  'Buddusò':     { dx: 28,  dy: 8,   anchor: 'start' },
  'Samassi':     { dx: -28, dy: 8,   anchor: 'end' },
  'Montresta':   { dx: -28, dy: 8,   anchor: 'end' },
  'Sarule':      { dx: 28,  dy: 8,   anchor: 'start' },
};

const points = communes.map(c => {
  const proj = project(c.lat, c.lng);
  const off = labelOffsets[c.nom] || { dx: 28, dy: 8, anchor: 'start' };
  return { ...c, ...proj, labelDx: off.dx, labelDy: off.dy, anchor: off.anchor };
});

// Labels for the panel — translated
const panelLabels = {
  fr: {
    region: 'Région',
    province: 'Province',
    population: 'Population',
    altitude: 'Altitude',
    attestation: 'Attestation',
    coords: 'Coordonnées',
    inhabitants: 'habitants',
    meters: 'm',
    clickHint: 'Cliquez sur un point de la carte pour afficher les détails de la commune.',
  },
  it: {
    region: 'Regione',
    province: 'Provincia',
    population: 'Popolazione',
    altitude: 'Altitudine',
    attestation: 'Attestazione',
    coords: 'Coordinate',
    inhabitants: 'abitanti',
    meters: 'm',
    clickHint: 'Clicca su un punto della mappa per visualizzare i dettagli del comune.',
  },
  en: {
    region: 'Region',
    province: 'Province',
    population: 'Population',
    altitude: 'Altitude',
    attestation: 'Attestation',
    coords: 'Coordinates',
    inhabitants: 'inhabitants',
    meters: 'm',
    clickHint: 'Click on a map point to display commune details.',
  },
};
const lp = panelLabels[lang];
---

<div class="bg-sardaigne-parchemin">

  <!-- Carte alignée à GAUCHE, panneau plus large à droite -->
  <div class="grid lg:grid-cols-[420px_1fr] gap-8 items-start">

    <!-- COLONNE GAUCHE : carte -->
    <div class="relative">

      <div class="mb-4">
        <div class="eyebrow">{t.name.map.eyebrow}</div>
        <h3 class="font-display text-2xl md:text-3xl text-sardaigne-encre mt-1">{t.name.map.title}</h3>
      </div>

      <!-- Container carte : pas de fond, pas de border, alignement à gauche naturel -->
      <div class="relative" style="aspect-ratio: 960 / 1759; max-width: 420px;">

        <img
          src="/images/sardegna-map.png"
          alt="Carte de la Sardaigne"
          class="absolute inset-0 w-full h-full object-contain pointer-events-none select-none"
          loading="lazy"
          draggable="false"
        />

        <svg viewBox={`0 0 ${W} ${H}`} class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

          <!-- Régions historiques (noms en filigrane) -->
          <g style="pointer-events: none;">
            <text x="540" y="380" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="32" fill="#8a6a3e" opacity="0.5">Gallura</text>
            <text x="560" y="780" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="34" fill="#8a6a3e" opacity="0.5">Barbagia</text>
            <text x="380" y="1020" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="30" fill="#8a6a3e" opacity="0.5">Oristano</text>
            <text x="700" y="1080" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="28" fill="#8a6a3e" opacity="0.5">Ogliastra</text>
            <text x="500" y="1380" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="32" fill="#8a6a3e" opacity="0.5">Campidano</text>
            <text x="380" y="270" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="26" fill="#8a6a3e" opacity="0.5">Sassarese</text>
          </g>

          {points.map((p, i) => (
            <g class="commune-point" data-index={i} style="cursor: pointer;">
              {p.priorite && (
                <circle cx={p.x} cy={p.y} r="32" fill="#9a1b1f" opacity="0.18" class="pulse-ring" style="pointer-events: none;"/>
              )}
              {Math.abs(p.labelDx) > 15 && (
                <line
                  x1={p.x}
                  y1={p.y}
                  x2={p.x + p.labelDx * 0.5}
                  y2={p.y + p.labelDy * 0.5}
                  stroke="#9a1b1f"
                  stroke-width="1.5"
                  opacity="0.4"
                  style="pointer-events: none;"
                />
              )}
              <circle
                cx={p.x}
                cy={p.y}
                r={p.priorite ? 14 : 10}
                fill="#9a1b1f"
                stroke="#f1e8d4"
                stroke-width="4"
                class="commune-dot"
              />
              <circle
                cx={p.x}
                cy={p.y}
                r="28"
                fill="transparent"
                class="commune-hitbox"
              />
              <text
                x={p.x + p.labelDx}
                y={p.y + p.labelDy}
                text-anchor={p.anchor}
                font-family="Inter Tight, sans-serif"
                font-size="26"
                font-weight="700"
                fill="#1f1a14"
                style="paint-order: stroke; stroke: #f1e8d4; stroke-width: 6px; stroke-linejoin: round; pointer-events: none;"
              >{p.nom}</text>
            </g>
          ))}

          <g transform="translate(880, 130)" opacity="0.7" style="pointer-events: none;">
            <circle cx="0" cy="0" r="42" fill="#f1e8d4" stroke="#1a150d" stroke-width="1.5"/>
            <line x1="0" y1="-42" x2="0" y2="42" stroke="#1a150d" stroke-width="1"/>
            <line x1="-42" y1="0" x2="42" y2="0" stroke="#1a150d" stroke-width="1"/>
            <text x="0" y="-50" text-anchor="middle" font-family="serif" font-size="18" fill="#1a150d" font-weight="bold">N</text>
            <polygon points="0,-30 -7,0 0,-7 7,0" fill="#9a1b1f"/>
          </g>

          <g transform="translate(60, 1680)" style="pointer-events: none;">
            <text x="0" y="0" font-family="monospace" font-size="18" fill="#1a150d" opacity="0.7">0    50    100   150 km</text>
            <line x1="0" y1="14" x2="240" y2="14" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="0" y1="9" x2="0" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="80" y1="9" x2="80" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="160" y1="9" x2="160" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="240" y1="9" x2="240" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
          </g>

        </svg>
      </div>

      <!-- Légende sous la carte -->
      <div class="mt-6 pt-4 border-t border-sardaigne-sepia/20 flex flex-wrap gap-4 items-center text-xs font-sans text-sardaigne-encre/70">
        <span class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-sardaigne-rouge ring-2 ring-sardaigne-rouge/30 ring-offset-1 ring-offset-sardaigne-parchemin"></span>
          {t.name.map.legendPriority}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-sardaigne-rouge/85"></span>
          {t.name.map.legendAttest}
        </span>
      </div>
    </div>

    <!-- COLONNE DROITE : panneau de détails ENRICHI -->
    <div id="commune-details" class="bg-sardaigne-encre text-sardaigne-parchemin p-8 md:p-10 min-h-[600px] flex flex-col relative overflow-hidden">

      <!-- Décor en arrière-plan -->
      <div class="absolute top-0 right-0 w-48 h-48 opacity-[0.04] pointer-events-none">
        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="40" fill="none" stroke="#fff" stroke-width="0.5"/>
          <circle cx="50" cy="50" r="30" fill="none" stroke="#fff" stroke-width="0.5"/>
          <circle cx="50" cy="50" r="20" fill="none" stroke="#fff" stroke-width="0.5"/>
        </svg>
      </div>

      <!-- En-tête commune -->
      <div class="relative">
        <div class="flex items-baseline justify-between gap-4 mb-2">
          <div class="eyebrow text-sardaigne-parchemin/70">{t.name.map.detailEyebrow}</div>
          <span class="text-sardaigne-rouge font-mono text-xs tracking-widest" id="commune-priority">{t.name.map.detailPriority}</span>
        </div>
        <h4 id="commune-name" class="font-display text-4xl md:text-5xl text-sardaigne-parchemin leading-tight">Villaputzu</h4>
        <div id="commune-region" class="font-serif italic text-pierre-200 mt-2"></div>
      </div>

      <div class="rule my-6 opacity-30"></div>

      <!-- Tableau de données enrichi -->
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm font-sans">
        <div>
          <dt class="eyebrow text-pierre-300 mb-1">{lp.province}</dt>
          <dd id="commune-province" class="font-serif text-base text-sardaigne-parchemin"></dd>
        </div>
        <div>
          <dt class="eyebrow text-pierre-300 mb-1">{lp.attestation}</dt>
          <dd id="commune-attestation" class="font-serif text-base text-sardaigne-parchemin"></dd>
        </div>
        <div>
          <dt class="eyebrow text-pierre-300 mb-1">{lp.population}</dt>
          <dd id="commune-population" class="font-serif text-base text-sardaigne-parchemin"></dd>
        </div>
        <div>
          <dt class="eyebrow text-pierre-300 mb-1">{lp.altitude}</dt>
          <dd id="commune-altitude" class="font-serif text-base text-sardaigne-parchemin"></dd>
        </div>
      </dl>

      <div class="rule my-6 opacity-30"></div>

      <!-- Notes longues -->
      <p id="commune-notes" class="font-serif text-[1rem] leading-relaxed text-pierre-100 flex-1">{lp.clickHint}</p>

      <!-- Pied du panneau : coordonnées GPS -->
      <div class="mt-6 pt-5 text-[0.7rem] font-mono text-pierre-300 flex items-center justify-between border-t border-pierre-700">
        <span>
          <span class="opacity-60">{lp.coords} :</span>
          <span id="commune-coords" class="ml-2">39.44° N · 9.57° E</span>
        </span>
        <span class="text-sardaigne-rouge text-xs">✦</span>
      </div>

    </div>

  </div>

</div>

<script define:vars={{ communes, lang, lp }}>
  const points = document.querySelectorAll('.commune-point');
  const els = {
    name: document.getElementById('commune-name'),
    region: document.getElementById('commune-region'),
    province: document.getElementById('commune-province'),
    attestation: document.getElementById('commune-attestation'),
    population: document.getElementById('commune-population'),
    altitude: document.getElementById('commune-altitude'),
    notes: document.getElementById('commune-notes'),
    coords: document.getElementById('commune-coords'),
    priority: document.getElementById('commune-priority'),
  };

  function selectCommune(i) {
    const c = communes[i];
    if (!c) return;
    if (els.name) els.name.textContent = c.nom;
    if (els.region) els.region.textContent = c.region || '';
    if (els.province) els.province.textContent = c.province || '—';
    if (els.attestation) els.attestation.textContent = c.attestation || '—';
    if (els.population) els.population.textContent = c.population
      ? `${c.population.toLocaleString('fr-FR')} ${lp.inhabitants}` : '—';
    if (els.altitude) els.altitude.textContent = c.altitude
      ? `${c.altitude} ${lp.meters}` : '—';

    // Notes localisées
    let noteText = c.notes;
    if (lang === 'it' && c.notesIt) noteText = c.notesIt;
    if (lang === 'en' && c.notesEn) noteText = c.notesEn;
    if (els.notes) els.notes.textContent = noteText || '';

    if (els.coords) els.coords.textContent = `${c.lat.toFixed(2)}° N · ${c.lng.toFixed(2)}° E`;
    if (els.priority) els.priority.style.visibility = c.priorite ? 'visible' : 'hidden';

    document.querySelectorAll('.commune-dot').forEach(dot => {
      const baseR = dot.getAttribute('data-base-r');
      if (baseR) dot.setAttribute('r', baseR);
    });
    const selectedDot = points[i].querySelector('.commune-dot');
    if (selectedDot) {
      if (!selectedDot.getAttribute('data-base-r')) {
        selectedDot.setAttribute('data-base-r', selectedDot.getAttribute('r'));
      }
      selectedDot.setAttribute('r', '18');
    }
  }

  points.forEach((point, i) => {
    point.addEventListener('click', () => selectCommune(i));
    point.addEventListener('touchend', (e) => { e.preventDefault(); selectCommune(i); });
  });

  // Sélection initiale : Villaputzu (commune prioritaire)
  if (points.length > 0) selectCommune(0);
</script>

<style>
  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.4); opacity: 0; }
  }
  .pulse-ring {
    transform-origin: center;
    transform-box: fill-box;
    animation: pulse-scale 2.5s ease-in-out infinite;
  }
  .commune-point:hover .commune-dot {
    filter: drop-shadow(0 0 8px rgba(154, 27, 31, 0.6));
  }
</style>
