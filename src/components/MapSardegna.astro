---
import { communes } from '../data/communes';
import { useTranslations } from '../i18n';
import type { Lang } from '../i18n/config';

export interface Props {
  lang?: Lang;
}
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);

// Dimensions de l'image authentique
const W = 960;
const H = 1759;

// Bounding box géographique (calibrée sur l'image)
const minLat = 38.83;
const maxLat = 41.27;
const minLng = 8.13;
const maxLng = 9.84;

function project(lat: number, lng: number) {
  const marginLeft = 0.06;
  const marginRight = 0.06;
  const marginTop = 0.03;
  const marginBottom = 0.03;
  const usableW = W * (1 - marginLeft - marginRight);
  const usableH = H * (1 - marginTop - marginBottom);
  const x = W * marginLeft + ((lng - minLng) / (maxLng - minLng)) * usableW;
  const y = H * marginTop + (1 - (lat - minLat) / (maxLat - minLat)) * usableH;
  return { x, y };
}

// Décalages manuels du libellé par commune, pour éviter chevauchements
// Format: { dx, dy, anchor } où anchor = 'start' (texte à droite) ou 'end' (à gauche)
const labelOffsets: Record<string, { dx: number; dy: number; anchor: 'start' | 'end' }> = {
  // Villaputzu et San Vito sont quasi-superposés au sud-est
  // Villaputzu en bas à droite, San Vito en haut à gauche
  'Villaputzu':  { dx: 28,  dy: 16,  anchor: 'start' },
  'San Vito':    { dx: -28, dy: -8,  anchor: 'end' },

  // Les autres : libellé à droite par défaut
  'Lula':        { dx: 28,  dy: 8,   anchor: 'start' },
  'Ghilarza':    { dx: -28, dy: 8,   anchor: 'end' },
  'Nuoro':       { dx: 28,  dy: 8,   anchor: 'start' },
  'Buddusò':     { dx: 28,  dy: 8,   anchor: 'start' },
  'Samassi':     { dx: -28, dy: 8,   anchor: 'end' },
  'Montresta':   { dx: -28, dy: 8,   anchor: 'end' },
  'Sarule':      { dx: 28,  dy: 8,   anchor: 'start' },
};

const points = communes.map(c => {
  const proj = project(c.lat, c.lng);
  const off = labelOffsets[c.nom] || { dx: 28, dy: 8, anchor: 'start' };
  return { ...c, ...proj, labelDx: off.dx, labelDy: off.dy, anchor: off.anchor };
});
---

<div class="bg-sardaigne-parchemin border border-sardaigne-encre/15 p-4 md:p-8">

  <div class="grid lg:grid-cols-[1fr_320px] gap-6 items-start">

    <div class="relative bg-sardaigne-parchemin">

      <div class="flex items-baseline justify-between mb-4 px-2">
        <div>
          <div class="eyebrow">{t.name.map.eyebrow}</div>
          <h3 class="font-display text-2xl md:text-3xl text-sardaigne-encre mt-1">{t.name.map.title}</h3>
        </div>
        <div class="font-mono text-[0.6rem] text-sardaigne-sepia">{t.name.map.detailScale}</div>
      </div>

      <!-- Carte : taille réduite, image en fond, SVG cliquable au-dessus -->
      <div class="relative mx-auto" style="aspect-ratio: 960 / 1759; max-width: 420px;">

        <!-- Image authentique en fond, NON cliquable -->
        <img
          src="/images/sardegna-map.png"
          alt="Carte de la Sardaigne"
          class="absolute inset-0 w-full h-full object-contain pointer-events-none select-none"
          loading="lazy"
          draggable="false"
        />

        <!-- SVG superposé : reçoit les clics -->
        <svg viewBox={`0 0 ${W} ${H}`} class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

          <!-- Régions historiques -->
          <g style="pointer-events: none;">
            <text x="540" y="380" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="32" fill="#8a6a3e" opacity="0.55">Gallura</text>
            <text x="560" y="780" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="34" fill="#8a6a3e" opacity="0.55">Barbagia</text>
            <text x="380" y="1020" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="30" fill="#8a6a3e" opacity="0.55">Oristano</text>
            <text x="700" y="1080" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="28" fill="#8a6a3e" opacity="0.55">Ogliastra</text>
            <text x="500" y="1380" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="32" fill="#8a6a3e" opacity="0.55">Campidano</text>
            <text x="380" y="270" text-anchor="middle" font-family="Cormorant Garamond, serif" font-style="italic" font-size="26" fill="#8a6a3e" opacity="0.55">Sassarese</text>
          </g>

          <!-- Points-communes : zone clic large, point + halo + label avec décalage personnalisé -->
          {points.map((p, i) => (
            <g class="commune-point" data-index={i} style="cursor: pointer;">
              <!-- Halo pulsé pour les points prioritaires -->
              {p.priorite && (
                <circle cx={p.x} cy={p.y} r="32" fill="#9a1b1f" opacity="0.18" class="pulse-ring" style="pointer-events: none;"/>
              )}

              <!-- Trait reliant le point à son libellé pour clarifier en cas de décalage important -->
              {Math.abs(p.labelDx) > 15 && (
                <line
                  x1={p.x}
                  y1={p.y}
                  x2={p.x + p.labelDx * 0.5}
                  y2={p.y + p.labelDy * 0.5}
                  stroke="#9a1b1f"
                  stroke-width="1.5"
                  opacity="0.4"
                  style="pointer-events: none;"
                />
              )}

              <!-- Le point lui-même (cliquable) -->
              <circle
                cx={p.x}
                cy={p.y}
                r={p.priorite ? 14 : 10}
                fill="#9a1b1f"
                stroke="#f1e8d4"
                stroke-width="4"
                class="commune-dot"
              />

              <!-- Zone de clic invisible plus large pour mobile -->
              <circle
                cx={p.x}
                cy={p.y}
                r="28"
                fill="transparent"
                class="commune-hitbox"
              />

              <!-- Libellé avec halo blanc pour lisibilité -->
              <text
                x={p.x + p.labelDx}
                y={p.y + p.labelDy}
                text-anchor={p.anchor}
                font-family="Inter Tight, sans-serif"
                font-size="26"
                font-weight="700"
                fill="#1f1a14"
                style="paint-order: stroke; stroke: #f1e8d4; stroke-width: 6px; stroke-linejoin: round; pointer-events: none;"
              >{p.nom}</text>
            </g>
          ))}

          <!-- Boussole -->
          <g transform="translate(880, 130)" opacity="0.7" style="pointer-events: none;">
            <circle cx="0" cy="0" r="42" fill="#f1e8d4" stroke="#1a150d" stroke-width="1.5"/>
            <line x1="0" y1="-42" x2="0" y2="42" stroke="#1a150d" stroke-width="1"/>
            <line x1="-42" y1="0" x2="42" y2="0" stroke="#1a150d" stroke-width="1"/>
            <text x="0" y="-50" text-anchor="middle" font-family="serif" font-size="18" fill="#1a150d" font-weight="bold">N</text>
            <polygon points="0,-30 -7,0 0,-7 7,0" fill="#9a1b1f"/>
          </g>

          <!-- Échelle -->
          <g transform="translate(60, 1680)" style="pointer-events: none;">
            <text x="0" y="0" font-family="monospace" font-size="18" fill="#1a150d" opacity="0.7">0    50    100   150 km</text>
            <line x1="0" y1="14" x2="240" y2="14" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="0" y1="9" x2="0" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="80" y1="9" x2="80" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="160" y1="9" x2="160" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
            <line x1="240" y1="9" x2="240" y2="19" stroke="#1a150d" stroke-width="2" opacity="0.7"/>
          </g>

        </svg>
      </div>
    </div>

    <!-- Détail commune -->
    <div id="commune-details" class="bg-sardaigne-encre text-sardaigne-parchemin p-6 min-h-[400px] flex flex-col">
      <div class="eyebrow text-sardaigne-parchemin/70">{t.name.map.detailEyebrow}</div>
      <h4 id="commune-name" class="font-display text-3xl mt-2 text-sardaigne-parchemin">Villaputzu</h4>
      <div id="commune-province" class="font-sans text-xs tracking-wider uppercase text-pierre-300 mt-1">Sud Sardaigne</div>
      <div class="rule my-4 opacity-40"></div>
      <p id="commune-notes" class="font-serif text-[0.95rem] leading-relaxed text-pierre-100">Cliquez sur un point pour afficher les informations.</p>
      <div class="mt-auto pt-6 text-[0.7rem] font-mono text-pierre-300 flex justify-between border-t border-pierre-700">
        <span id="commune-coords">39.44° N · 9.57° E</span>
        <span class="text-sardaigne-rouge" id="commune-priority">{t.name.map.detailPriority}</span>
      </div>
    </div>
  </div>

  <div class="mt-6 pt-4 border-t border-sardaigne-sepia/20 flex flex-wrap gap-5 items-center text-xs font-sans text-sardaigne-encre/70">
    <span class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-sardaigne-rouge ring-2 ring-sardaigne-rouge/30 ring-offset-1 ring-offset-sardaigne-parchemin"></span>
      {t.name.map.legendPriority}
    </span>
    <span class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-sardaigne-rouge/85"></span>
      {t.name.map.legendAttest}
    </span>
    <span class="italic text-sardaigne-sepia">{t.name.map.legendHint}</span>
  </div>

</div>

<script define:vars={{ communes }}>
  // Sélection des éléments cliquables (groupes <g> avec class commune-point)
  const points = document.querySelectorAll('.commune-point');
  const nameEl = document.getElementById('commune-name');
  const provEl = document.getElementById('commune-province');
  const notesEl = document.getElementById('commune-notes');
  const coordsEl = document.getElementById('commune-coords');
  const priorityEl = document.getElementById('commune-priority');

  function selectCommune(i) {
    const c = communes[i];
    if (!c) return;
    if (nameEl) nameEl.textContent = c.nom;
    if (provEl) provEl.textContent = c.province || '';
    if (notesEl) notesEl.textContent = c.notes || '';
    if (coordsEl) coordsEl.textContent = `${c.lat.toFixed(2)}° N · ${c.lng.toFixed(2)}° E`;
    if (priorityEl) priorityEl.style.visibility = c.priorite ? 'visible' : 'hidden';

    // Highlight visuel : grossir le point sélectionné
    document.querySelectorAll('.commune-dot').forEach(dot => {
      dot.setAttribute('r', dot.getAttribute('data-base-r') || '10');
    });
    const selectedDot = points[i].querySelector('.commune-dot');
    if (selectedDot) {
      if (!selectedDot.getAttribute('data-base-r')) {
        selectedDot.setAttribute('data-base-r', selectedDot.getAttribute('r'));
      }
      selectedDot.setAttribute('r', '18');
    }
  }

  points.forEach((point, i) => {
    point.addEventListener('click', () => selectCommune(i));
    point.addEventListener('touchend', (e) => { e.preventDefault(); selectCommune(i); });
  });
</script>

<style>
  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.4); opacity: 0; }
  }
  .pulse-ring {
    transform-origin: center;
    transform-box: fill-box;
    animation: pulse-scale 2.5s ease-in-out infinite;
  }
  .commune-point:hover .commune-dot {
    filter: drop-shadow(0 0 8px rgba(154, 27, 31, 0.6));
  }
</style>
