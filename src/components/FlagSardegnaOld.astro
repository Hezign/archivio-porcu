---
// Drapeau de la Sardaigne — version ancienne (XIXᵉ siècle - 1999)
// Bandeau sur les YEUX, têtes tournées vers la gauche (côté hampe)
// Mêmes dimensions et style que la version moderne pour comparaison

export interface Props {
  size?: number;
  className?: string;
}
const { size = 300, className = '' } = Astro.props;
const w = size;
const h = Math.round(size * 2 / 3);
---

<svg
  viewBox="0 0 600 400"
  width={w}
  height={h}
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Drapeau historique de la Sardaigne (XIXᵉ-1999) - Quattro Mori avec bandeau sur les yeux"
>
  <rect x="0" y="0" width="600" height="400" fill="#ffffff"/>

  <!-- Croix de Saint-Georges -->
  <rect x="0" y="170" width="600" height="60" fill="#cc1f1f"/>
  <rect x="270" y="0" width="60" height="400" fill="#cc1f1f"/>

  <!-- ============ Quatre têtes — orientation INVERSE (vers la hampe) ============ -->
  <!-- transform scale(-1, 1) inverse horizontalement chaque tête -->

  <g id="moor-q1-old" transform="translate(135, 85)">
    <g transform="scale(-1, 1)">
      <path d="M -28,-15 C -32,-30 -22,-42 -8,-44 C 8,-46 22,-40 28,-25 C 32,-10 30,8 24,18 C 18,28 8,32 -2,30 C -8,29 -14,26 -18,20 L -22,24 L -26,20 L -28,12 L -32,8 L -30,-2 L -28,-15 Z" fill="#1a1a1a"/>
      <!-- Bandeau sur les YEUX (positionné plus bas que la version moderne) -->
      <path d="M -30,-8 L 30,-8 L 30,4 L -30,4 Z" fill="#ffffff"/>
      <!-- Détail bouche (en bas) -->
      <path d="M 14,16 L 22,15" stroke="#ffffff" stroke-width="1" fill="none" opacity="0.5"/>
    </g>
  </g>

  <g id="moor-q2-old" transform="translate(465, 85)">
    <g transform="scale(-1, 1)">
      <path d="M -28,-15 C -32,-30 -22,-42 -8,-44 C 8,-46 22,-40 28,-25 C 32,-10 30,8 24,18 C 18,28 8,32 -2,30 C -8,29 -14,26 -18,20 L -22,24 L -26,20 L -28,12 L -32,8 L -30,-2 L -28,-15 Z" fill="#1a1a1a"/>
      <path d="M -30,-8 L 30,-8 L 30,4 L -30,4 Z" fill="#ffffff"/>
      <path d="M 14,16 L 22,15" stroke="#ffffff" stroke-width="1" fill="none" opacity="0.5"/>
    </g>
  </g>

  <g id="moor-q3-old" transform="translate(135, 315)">
    <g transform="scale(-1, 1)">
      <path d="M -28,-15 C -32,-30 -22,-42 -8,-44 C 8,-46 22,-40 28,-25 C 32,-10 30,8 24,18 C 18,28 8,32 -2,30 C -8,29 -14,26 -18,20 L -22,24 L -26,20 L -28,12 L -32,8 L -30,-2 L -28,-15 Z" fill="#1a1a1a"/>
      <path d="M -30,-8 L 30,-8 L 30,4 L -30,4 Z" fill="#ffffff"/>
      <path d="M 14,16 L 22,15" stroke="#ffffff" stroke-width="1" fill="none" opacity="0.5"/>
    </g>
  </g>

  <g id="moor-q4-old" transform="translate(465, 315)">
    <g transform="scale(-1, 1)">
      <path d="M -28,-15 C -32,-30 -22,-42 -8,-44 C 8,-46 22,-40 28,-25 C 32,-10 30,8 24,18 C 18,28 8,32 -2,30 C -8,29 -14,26 -18,20 L -22,24 L -26,20 L -28,12 L -32,8 L -30,-2 L -28,-15 Z" fill="#1a1a1a"/>
      <path d="M -30,-8 L 30,-8 L 30,4 L -30,4 Z" fill="#ffffff"/>
      <path d="M 14,16 L 22,15" stroke="#ffffff" stroke-width="1" fill="none" opacity="0.5"/>
    </g>
  </g>

</svg>
