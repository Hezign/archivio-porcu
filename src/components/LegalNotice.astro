---
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props {
  variant?: 'default' | 'strong' | 'genealogie';
  lang?: Lang;
}
const { variant = 'default', lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const prefix = langPrefix(lang);
const removalPath = `${prefix}/${pageSlugs.legalRemoval[lang]}/`;
---

{variant === 'strong' && (
  <div class="bg-sardaigne-rouge/5 border-l-4 border-sardaigne-rouge p-6 md:p-8">
    <div class="eyebrow">{t.components.legalNoticeStrong.eyebrow}</div>
    <p class="font-serif text-[1.05rem] mt-3 leading-relaxed text-sardaigne-encre">
      {t.components.legalNoticeStrong.text}
    </p>
    <p class="font-sans text-xs mt-4 text-sardaigne-encre/70" style="letter-spacing:0.05em;">
      <a href={removalPath} class="underline text-sardaigne-rouge hover:text-sardaigne-rouge-sombre">{t.components.legalNoticeStrong.cta}</a>
    </p>
  </div>
)}

{variant === 'genealogie' && (
  <div class="bg-sardaigne-encre text-sardaigne-parchemin p-6 md:p-8 border-l-4 border-sardaigne-rouge">
    <div class="eyebrow text-sardaigne-parchemin/70">{t.genealogy.legalNotice.eyebrow}</div>
    <p class="font-serif text-[1.02rem] mt-3 leading-relaxed text-pierre-100">
      {t.genealogy.legalNotice.text}
    </p>
    <a href={removalPath} class="inline-flex items-center gap-2 mt-4 font-sans text-xs text-sardaigne-rouge hover:text-sardaigne-parchemin transition-colors" style="letter-spacing:0.2em;text-transform:uppercase;">
      {t.genealogy.legalNotice.cta}
    </a>
  </div>
)}

{variant === 'default' && (
  <div class="border border-sardaigne-encre/20 bg-sardaigne-parchemin p-6">
    <p class="font-serif text-sm leading-relaxed text-sardaigne-encre/85">
      {t.ui.footerEthical}
      <a href={removalPath} class="underline text-sardaigne-rouge">{t.ui.footerEthicalLink}</a>.
    </p>
  </div>
)}
