---
import Layout from '../layouts/Layout.astro';
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const p = t.legal.privacy;
const prefix = langPrefix(lang);

function pathFor(key: keyof typeof pageSlugs): string {
  const slug = pageSlugs[key][lang];
  if (!slug) return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}/${slug}/`;
}
---

<Layout title={p.metaTitle} lang={lang} pageKey="legalPrivacy">

  <section class="max-w-3xl mx-auto px-6 pt-24 pb-16 border-b border-sardaigne-encre/15">
    <div class="eyebrow">{p.eyebrow}</div>
    <h1 class="font-display text-5xl md:text-6xl mt-4 text-sardaigne-encre leading-[0.95]">
      {p.title1} <em class="text-sardaigne-rouge">{p.title2}</em>
    </h1>
    <p class="font-serif text-lg mt-6 text-sardaigne-encre/80 italic">{p.sub}</p>
  </section>

  <article class="max-w-3xl mx-auto px-6 py-16 font-serif text-[1.05rem] leading-relaxed text-sardaigne-encre/90 space-y-12">

    <p class="drop-cap text-lg">{p.intro}</p>

    <div class="rule"></div>

    <section>
      <div class="eyebrow mb-3">{p.s1Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s1Title}</h2>
      <p>{p.s1Text}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s2Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s2Title}</h2>
      <p>{p.s2Text}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s3Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s3Title}</h2>
      <p>{p.s3Text}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s4Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s4Title}</h2>
      <p>{p.s4Text}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s5Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s5Title}</h2>
      <p>{p.s5Text}</p>
      <div class="grid md:grid-cols-2 gap-4 mt-6">
        {p.rights.map(r => (
          <div class="border-l-2 border-sardaigne-rouge pl-4 py-1">
            <div class="font-display text-lg text-sardaigne-encre">{r.t}</div>
            <p class="font-sans text-sm text-sardaigne-encre/75 mt-1">{r.d}</p>
          </div>
        ))}
      </div>
      <p class="mt-6">{p.s5After}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s6Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s6Title}</h2>
      <p>{p.s6Text}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s7Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s7Title}</h2>
      <p>{p.s7Text}</p>
    </section>

    <section>
      <div class="eyebrow mb-3">{p.s8Eyebrow}</div>
      <h2 class="font-display text-3xl text-sardaigne-encre mb-4">{p.s8Title}</h2>
      <p>{p.s8Text}</p>
      <p class="mt-4 font-mono text-xs text-sardaigne-sepia">{p.lastUpdate}</p>
    </section>

    <div class="pt-10 border-t border-sardaigne-encre/15">
      <div class="grid md:grid-cols-2 gap-4 text-sm font-sans">
        <a href={pathFor('legalRemoval')} class="block p-5 border border-sardaigne-encre/20 hover:bg-sardaigne-encre hover:text-sardaigne-parchemin transition-colors">
          <div class="eyebrow mb-2">{t.legal.mentions.navRights}</div>
          {t.legal.mentions.navRemoval}
        </a>
        <a href={pathFor('legalMentions')} class="block p-5 border border-sardaigne-encre/20 hover:bg-sardaigne-encre hover:text-sardaigne-parchemin transition-colors">
          <div class="eyebrow mb-2">{t.legal.mentions.navBack}</div>
          {t.ui.legalLinks.mentions} →
        </a>
      </div>
    </div>

  </article>

</Layout>
