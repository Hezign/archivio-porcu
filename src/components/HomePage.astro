---
import Layout from '../layouts/Layout.astro';
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = langPrefix(lang);

function pathFor(key: keyof typeof pageSlugs): string {
  const slug = pageSlugs[key][lang];
  if (!slug) return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}/${slug}/`;
}
---

<Layout title={t.home.metaTitle} description={t.home.metaTitle} lang={lang} pageKey="home">

  <!-- HERO -->
  <section class="relative overflow-hidden min-h-[92vh] flex items-center border-b border-sardaigne-encre/15">

    <div class="absolute inset-0 opacity-[0.035] pointer-events-none">
      <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" class="w-full h-full">
        <line x1="400" y1="0" x2="400" y2="600" stroke="#9a1b1f" stroke-width="40"/>
        <line x1="0" y1="300" x2="800" y2="300" stroke="#9a1b1f" stroke-width="40"/>
      </svg>
    </div>
    <div class="absolute inset-0 topo-lines opacity-60 pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-20 w-full grid lg:grid-cols-12 gap-10 items-center">

      <div class="lg:col-span-7">
        <div class="fade-up stagger-1 flex items-center gap-4 mb-8">
          <span class="h-[1px] w-16 bg-sardaigne-rouge"></span>
          <span class="eyebrow">{t.home.heroEyebrow}</span>
        </div>

        <h1 class="fade-up stagger-2 font-display leading-[0.9] text-sardaigne-encre" style="font-size:clamp(3.5rem,12vw,7rem);">
          <span class="block italic text-sardaigne-sepia">{t.home.heroTitle1}</span>
          <span class="block">{t.home.heroTitle2}</span>
          <span class="block text-sardaigne-rouge">{t.home.heroTitle3}</span>
        </h1>

        <div class="fade-up stagger-3 max-w-xl mt-10">
          <p class="font-serif text-lg md:text-xl leading-relaxed text-sardaigne-encre/90 drop-cap">
            {t.home.heroIntro}
          </p>
        </div>

        <div class="fade-up stagger-4 mt-10 flex flex-wrap gap-4">
          <a href={pathFor('name')} class="group inline-flex items-center gap-3 bg-sardaigne-encre text-sardaigne-parchemin px-7 py-4 font-sans text-sm uppercase hover:bg-sardaigne-rouge transition-colors" style="letter-spacing:0.2em;">
            {t.home.ctaExplore}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
          <a href={pathFor('genealogy')} class="group inline-flex items-center gap-3 border border-sardaigne-encre/40 text-sardaigne-encre px-7 py-4 font-sans text-sm uppercase hover:bg-sardaigne-encre hover:text-sardaigne-parchemin transition-colors" style="letter-spacing:0.2em;">
            {t.home.ctaContribute}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>

      <div class="fade-up stagger-5 lg:col-span-5 relative">
        <div class="relative bg-sardaigne-encre text-sardaigne-parchemin p-10 md:p-12 flex flex-col justify-between" style="aspect-ratio:4/5;">
          <div class="absolute top-4 left-4 w-8 h-8 border-l border-t border-sardaigne-parchemin/30"></div>
          <div class="absolute top-4 right-4 w-8 h-8 border-r border-t border-sardaigne-parchemin/30"></div>
          <div class="absolute bottom-4 left-4 w-8 h-8 border-l border-b border-sardaigne-parchemin/30"></div>
          <div class="absolute bottom-4 right-4 w-8 h-8 border-r border-b border-sardaigne-parchemin/30"></div>

          <div>
            <div class="eyebrow text-sardaigne-parchemin/70">{t.home.plaqueEtymology}</div>
            <div class="font-display mt-4 text-sardaigne-rouge" style="font-size:clamp(4rem,7vw,7rem);line-height:0.85;">P</div>
          </div>

          <div>
            <div class="font-display text-4xl md:text-5xl leading-tight italic">{t.home.plaqueWord}</div>
            <div class="mt-4 font-serif text-base text-pierre-100">
              <span class="font-sans text-[0.7rem] uppercase text-pierre-300" style="letter-spacing:0.2em;">{t.home.plaqueGloss}</span>
              <br/>
              {t.home.plaqueDef}
            </div>
          </div>

          <div class="rule opacity-40"></div>

          <div class="flex justify-between items-end font-mono text-[0.7rem] text-pierre-300" style="letter-spacing:0.2em;">
            <span>VILLAPUTZU</span>
            <span>GHILARZA</span>
            <span>LULA</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-12">
    <div class="ornament">✦ ✦ ✦</div>
  </section>

  <!-- MANIFESTO -->
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="eyebrow text-center">{t.home.manifestoEyebrow}</div>
    <h2 class="font-display text-4xl md:text-6xl text-center mt-4 leading-tight">
      <em class="text-sardaigne-rouge">« </em>{t.home.manifestoTitle}<em class="text-sardaigne-rouge"> »</em>
    </h2>
    <div class="rule mt-10"></div>
    <p class="font-serif text-lg md:text-xl leading-relaxed mt-10 text-sardaigne-encre/90">
      {t.home.manifestoP1}
    </p>
    <p class="font-serif text-lg md:text-xl leading-relaxed mt-6 text-sardaigne-encre/90">
      {t.home.manifestoP2}
    </p>
  </section>

  <!-- INDEX 6 CHAPITRES -->
  <section class="bg-sardaigne-encre text-sardaigne-parchemin py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-10 mb-16">
        <div class="lg:col-span-4">
          <div class="eyebrow text-sardaigne-parchemin/70">{t.home.indexEyebrow}</div>
          <h2 class="font-display text-5xl md:text-6xl mt-4 text-sardaigne-parchemin leading-[0.95]">
            {t.home.indexTitle1}<br/>
            <em class="text-sardaigne-rouge">{t.home.indexTitle2}</em>
          </h2>
        </div>
        <div class="lg:col-span-8 flex items-end">
          <p class="font-serif text-lg md:text-xl text-pierre-100 leading-relaxed">
            {t.home.indexLead}
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-[1px] bg-pierre-800">
        {t.home.chapters.map((item, i) => {
          // Match num to pageKey
          const keyMap = ['name', 'sardinia', 'banditry', 'anonima', 'genealogy', 'genealogy'] as const;
          const href = pathFor(keyMap[i]);
          return (
            <a href={href} class="group bg-sardaigne-encre hover:bg-pierre-900 p-8 transition-colors relative overflow-hidden">
              <div class="font-display text-6xl italic text-sardaigne-rouge/80 mb-4 group-hover:text-sardaigne-rouge transition-colors">
                {item.num}
              </div>
              <h3 class="font-display text-2xl text-sardaigne-parchemin mb-3">{item.title}</h3>
              <p class="font-serif text-sm text-pierre-200 leading-relaxed">{item.desc}</p>
              <div class="mt-6 font-sans text-[0.7rem] uppercase text-sardaigne-parchemin/60 group-hover:text-sardaigne-rouge transition-colors" style="letter-spacing:0.2em;">
                {t.ui.read} →
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- DIASPORA -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-28">
        <div class="eyebrow">{t.home.diasporaEyebrow}</div>
        <h2 class="font-display text-5xl md:text-6xl mt-4 text-sardaigne-encre leading-[0.95]">
          {t.home.diasporaTitle1} <em class="text-sardaigne-rouge">{t.home.diasporaTitle2}</em><br/>
          {t.home.diasporaTitle3}<br/>
          <em>{t.home.diasporaTitle4}</em>
        </h2>
      </div>
      <div class="lg:col-span-7 font-serif text-lg leading-relaxed text-sardaigne-encre/90 space-y-6">
        <p>{t.home.diasporaP1}</p>
        <p>{t.home.diasporaP2}</p>
        <p>{t.home.diasporaP3}</p>

        <div class="grid grid-cols-2 gap-8 pt-10 mt-10 border-t border-sardaigne-encre/15">
          <div>
            <div class="font-display text-5xl text-sardaigne-rouge">1950s</div>
            <div class="font-sans text-xs uppercase text-sardaigne-sepia mt-2" style="letter-spacing:0.2em;">{t.home.diasporaStat1}</div>
          </div>
          <div>
            <div class="font-display text-5xl text-sardaigne-rouge">2018</div>
            <div class="font-sans text-xs uppercase text-sardaigne-sepia mt-2" style="letter-spacing:0.2em;">{t.home.diasporaStat2}</div>
          </div>
        </div>

        <a href={`${pathFor('name')}#diaspora`} class="inline-flex items-center gap-3 mt-10 font-sans text-sm uppercase text-sardaigne-encre hover:text-sardaigne-rouge transition-colors border-b border-sardaigne-encre hover:border-sardaigne-rouge pb-1" style="letter-spacing:0.2em;">
          {t.home.diasporaCta}
          <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CITATION CLÔTURE -->
  <section class="max-w-4xl mx-auto px-6 py-24 text-center">
    <div class="ornament">✦</div>
    <blockquote class="font-display italic text-3xl md:text-5xl leading-tight text-sardaigne-encre mt-10">
      {t.home.quote}
    </blockquote>
    <p class="font-sans text-xs uppercase text-sardaigne-sepia mt-8" style="letter-spacing:0.25em;">
      {t.home.quoteSub}
    </p>
  </section>

</Layout>
