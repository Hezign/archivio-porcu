---
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props { lang?: Lang; }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const c = t.genealogy.contrib;
const prefix = langPrefix(lang);
const privacyPath = `${prefix}/${pageSlugs.legalPrivacy[lang]}/`;
const removalPath = `${prefix}/${pageSlugs.legalRemoval[lang]}/`;
---

<div class="bg-sardaigne-encre text-sardaigne-parchemin p-8 md:p-12 relative overflow-hidden">

  <div class="absolute top-0 right-0 w-64 h-64 opacity-10">
    <svg viewBox="0 0 100 100" class="w-full h-full">
      <circle cx="50" cy="50" r="40" fill="none" stroke="#9a1b1f" stroke-width="0.5"/>
      <circle cx="50" cy="50" r="30" fill="none" stroke="#9a1b1f" stroke-width="0.5"/>
      <circle cx="50" cy="50" r="20" fill="none" stroke="#9a1b1f" stroke-width="0.5"/>
      <line x1="50" y1="0" x2="50" y2="100" stroke="#9a1b1f" stroke-width="0.3"/>
      <line x1="0" y1="50" x2="100" y2="50" stroke="#9a1b1f" stroke-width="0.3"/>
    </svg>
  </div>

  <div class="relative max-w-2xl">
    <div class="eyebrow text-sardaigne-parchemin/70">{c.eyebrow}</div>
    <h3 class="font-display text-3xl md:text-4xl text-sardaigne-parchemin mt-3 leading-tight">
      {c.title}
    </h3>
    <p class="font-serif text-pierre-100 mt-5 leading-relaxed">
      {c.lead}
    </p>

    <form id="contrib-form" class="mt-10 space-y-6" action="#" method="POST" data-confirm={c.submitConfirm}>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label class="block eyebrow text-pierre-300 mb-2">{c.firstName}</label>
          <input type="text" name="prenom" required
            class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg transition-colors" />
        </div>
        <div>
          <label class="block eyebrow text-pierre-300 mb-2">{c.lastName}</label>
          <input type="text" name="nom" required
            class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg transition-colors" />
        </div>
      </div>

      <div>
        <label class="block eyebrow text-pierre-300 mb-2">{c.email}</label>
        <input type="email" name="email" required
          class="w-full bg-transparent border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg transition-colors" />
      </div>

      <div>
        <label class="block eyebrow text-pierre-300 mb-2">{c.relation}</label>
        <select name="lien"
          class="w-full bg-sardaigne-encre border-b border-pierre-400/50 focus:border-sardaigne-rouge outline-none py-2 text-sardaigne-parchemin font-serif text-lg">
          {c.relationOpts.map(opt => <option>{opt}</option>)}
        </select>
      </div>

      <div>
        <label class="block eyebrow text-pierre-300 mb-2">{c.message}</label>
        <textarea name="message" rows="5" placeholder={c.messagePlaceholder}
          class="w-full bg-transparent border border-pierre-400/30 focus:border-sardaigne-rouge outline-none p-3 text-sardaigne-parchemin font-serif transition-colors resize-none"></textarea>
      </div>

      <div class="bg-sardaigne-encre/50 border border-pierre-400/20 p-5 mt-8">
        <div class="eyebrow text-pierre-300 mb-3">{c.gdprEyebrow}</div>
        <ul class="space-y-2 font-sans text-xs text-pierre-200 leading-relaxed">
          <li class="flex gap-2"><span class="text-sardaigne-rouge">✦</span><span><strong class="text-sardaigne-parchemin">{c.gdpr1Label}</strong> {c.gdpr1}</span></li>
          <li class="flex gap-2"><span class="text-sardaigne-rouge">✦</span><span><strong class="text-sardaigne-parchemin">{c.gdpr2Label}</strong> {c.gdpr2}</span></li>
          <li class="flex gap-2"><span class="text-sardaigne-rouge">✦</span><span><strong class="text-sardaigne-parchemin">{c.gdpr3Label}</strong> {c.gdpr3}</span></li>
          <li class="flex gap-2"><span class="text-sardaigne-rouge">✦</span><span><strong class="text-sardaigne-parchemin">{c.gdpr4Label}</strong>{c.gdpr4}</span></li>
        </ul>
      </div>

      <label class="flex items-start gap-3 text-xs font-sans text-pierre-200">
        <input type="checkbox" required class="mt-1 accent-sardaigne-rouge" />
        <span>
          {c.consent}
          <a href={privacyPath} class="underline text-sardaigne-rouge hover:text-sardaigne-parchemin">{c.consentLink1}</a>{c.consent2}
          <a href={removalPath} class="underline text-sardaigne-rouge hover:text-sardaigne-parchemin">{c.consentLink2}</a>.
        </span>
      </label>

      <button type="submit"
        class="group inline-flex items-center gap-3 bg-sardaigne-rouge hover:bg-sardaigne-rouge-sombre text-sardaigne-parchemin px-8 py-4 font-sans text-sm tracking-widest uppercase transition-colors">
        <span>{c.submit}</span>
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </button>

    </form>
  </div>
</div>

<script>
  const form = document.getElementById('contrib-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const msg = form.dataset.confirm || 'Merci !';
    alert(msg);
  });
</script>
