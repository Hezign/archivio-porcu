---
import Layout from '../layouts/Layout.astro';
import { useTranslations, pageSlugs } from '../i18n';
import { langPrefix } from '../i18n/config';
import type { Lang } from '../i18n/config';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = langPrefix(lang);

function pathFor(key: keyof typeof pageSlugs): string {
  const slug = pageSlugs[key][lang];
  if (!slug) return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}/${slug}/`;
}
---

<Layout title={t.sardinia.metaTitle} lang={lang} pageKey="sardinia">

  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16 border-b border-sardaigne-encre/15">
    <div class="grid lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-2 font-display italic text-7xl text-sardaigne-rouge">III</div>
      <div class="lg:col-span-10">
        <div class="eyebrow">{t.ui.chapter} {t.ui.chapters[2]}</div>
        <h1 class="font-display text-5xl md:text-7xl mt-3 leading-[0.95] text-sardaigne-encre">
          <em class="text-sardaigne-rouge">{t.sardinia.chapterTitle1}</em><br/>
          {t.sardinia.chapterTitle2}
        </h1>
        <p class="font-serif text-xl mt-6 text-sardaigne-encre/80 italic max-w-3xl">
          {t.sardinia.chapterSub}
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20">
    <p class="font-serif text-xl md:text-2xl leading-relaxed text-sardaigne-encre/90 drop-cap">
      {t.sardinia.intro}
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5 lg:sticky lg:top-28 lg:self-start">
        <div class="eyebrow">{t.sardinia.flagEyebrow}</div>
        <h2 class="font-display text-4xl md:text-6xl mt-4 text-sardaigne-encre leading-[0.95]">
          {t.sardinia.flagTitle1}<br/>
          {t.sardinia.flagTitle2} <em class="text-sardaigne-rouge">{t.sardinia.flagTitle3}</em>
        </h2>
      </div>
      <div class="lg:col-span-7 font-serif space-y-5 text-sardaigne-encre/90 text-lg leading-relaxed">
        <p>{t.sardinia.flagP1}</p>
        <p>{t.sardinia.flagP2}</p>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 gap-[1px] bg-sardaigne-encre">

      <!-- VERSION ANCIENNE, yeux bandés -->
      <div class="bg-sardaigne-parchemin p-8 md:p-10">
        <div class="flex items-start justify-between mb-6">
          <div>
            <div class="eyebrow text-sardaigne-sepia">{t.sardinia.flagOldEyebrow}</div>
            <div class="font-display text-2xl md:text-3xl mt-1 text-sardaigne-encre">{t.sardinia.flagOldTitle}</div>
          </div>
          <div class="font-mono text-[0.7rem] tracking-widest text-sardaigne-sepia text-right">
            {t.sardinia.flagOldPeriod}
          </div>
        </div>

        <div class="relative bg-white shadow-[0_20px_60px_-20px_rgba(26,21,13,0.25)] aspect-[3/2] p-8">
          <img
            src="/images/flag-sardegna-old.png"
            alt="Drapeau historique de la Sardaigne, Quattro Mori avec bandeau sur les yeux (XIXᵉ siècle - 1999)"
            class="w-full h-full object-contain select-none"
            loading="lazy"
            draggable="false"
          />
        </div>

        <div class="mt-6 pt-6 border-t border-sardaigne-encre/15">
          <div class="flex items-start gap-3">
            <span class="text-sardaigne-sepia font-display text-2xl leading-none">⟁</span>
            <div>
              <div class="font-sans text-xs tracking-widest uppercase text-sardaigne-sepia mb-2">{t.sardinia.flagOldRead}</div>
              <p class="font-serif text-[1.02rem] leading-relaxed text-sardaigne-encre/85">
                {t.sardinia.flagOldText}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- VERSION OFFICIELLE, bandeau relevé -->
      <div class="bg-sardaigne-encre text-sardaigne-parchemin p-8 md:p-10">
        <div class="flex items-start justify-between mb-6">
          <div>
            <div class="eyebrow text-sardaigne-parchemin/70">{t.sardinia.flagNewEyebrow}</div>
            <div class="font-display text-2xl md:text-3xl mt-1 text-sardaigne-parchemin">{t.sardinia.flagNewTitle}</div>
          </div>
          <div class="font-mono text-[0.7rem] tracking-widest text-sardaigne-rouge text-right">
            {t.sardinia.flagNewPeriod}<br/><strong class="text-base">1999</strong>
          </div>
        </div>

        <div class="relative bg-white shadow-[0_20px_60px_-20px_rgba(0,0,0,0.5)] aspect-[3/2] p-8">
          <img
            src="/images/flag-sardegna-modern.png"
            alt="Drapeau officiel de la Sardaigne, Quattro Mori avec bandeau sur le front (depuis 1999)"
            class="w-full h-full object-contain select-none"
            loading="lazy"
            draggable="false"
          />
        </div>

        <div class="mt-6 pt-6 border-t border-pierre-700">
          <div class="flex items-start gap-3">
            <span class="text-sardaigne-rouge font-display text-2xl leading-none">✦</span>
            <div>
              <div class="font-sans text-xs tracking-widest uppercase text-sardaigne-rouge mb-2">{t.sardinia.flagNewRead}</div>
              <p class="font-serif text-[1.02rem] leading-relaxed text-pierre-100">
                {t.sardinia.flagNewText}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-16">
    <div class="border-l-4 border-sardaigne-rouge pl-8 py-4">
      <div class="eyebrow">{t.sardinia.flagSynthEyebrow}</div>
      <p class="font-display text-2xl md:text-3xl italic text-sardaigne-encre leading-snug mt-4">
        {t.sardinia.flagSynth}
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-[1px] bg-sardaigne-encre/15">
      {t.sardinia.flagStats.map(s => (
        <div class="bg-sardaigne-parchemin p-8 text-center">
          <div class="font-display text-4xl md:text-5xl text-sardaigne-rouge">{s.num}</div>
          <div class="font-sans text-[0.65rem] tracking-widest uppercase text-sardaigne-sepia mt-3">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-sardaigne-encre text-sardaigne-parchemin py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-16">
        <div class="eyebrow text-sardaigne-parchemin/70">{t.sardinia.langEyebrow}</div>
        <h2 class="font-display text-5xl md:text-6xl mt-4 text-sardaigne-parchemin leading-[0.95]">
          {t.sardinia.langTitle1} <em class="text-sardaigne-rouge">{t.sardinia.langTitle2}</em>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-[1px] bg-pierre-800">
        {t.sardinia.langs.map(l => (
          <div class="bg-sardaigne-encre p-8">
            <div class="font-display text-2xl text-sardaigne-parchemin">{l.name}</div>
            <div class="eyebrow text-sardaigne-parchemin/60 mt-2">{l.zone}</div>
            <p class="font-serif text-sm text-pierre-200 mt-4 leading-relaxed">{l.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="max-w-3xl mb-12">
      <div class="eyebrow">{t.sardinia.timeEyebrow}</div>
      <h2 class="font-display text-4xl md:text-5xl mt-3 text-sardaigne-encre leading-tight">
        {t.sardinia.timeTitle1}<br/><em class="text-sardaigne-rouge">{t.sardinia.timeTitle2}</em>
      </h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      {t.sardinia.timeline.map(r => (
        <div class="border-l-2 border-sardaigne-rouge pl-6 py-2">
          <div class="eyebrow text-sardaigne-sepia">{r.date}</div>
          <h3 class="font-display text-2xl mt-2 text-sardaigne-encre">{r.titre}</h3>
          <p class="font-serif text-sardaigne-encre/85 mt-2 leading-relaxed">{r.texte}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20 text-center">
    <div class="ornament">✦</div>
    <p class="font-display italic text-2xl md:text-3xl mt-10 text-sardaigne-encre/80">
      {t.sardinia.transitionQuote}
    </p>
    <a href={pathFor('banditry')} class="inline-flex items-center gap-3 mt-10 font-sans text-sm tracking-widest uppercase text-sardaigne-encre hover:text-sardaigne-rouge transition-colors border-b border-sardaigne-encre hover:border-sardaigne-rouge pb-1">
      {t.sardinia.transitionLink}
      <span>→</span>
    </a>
  </section>

</Layout>
