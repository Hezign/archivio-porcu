---
import '../styles/global.css';
import { useTranslations, pageSlugs, type PageKey } from '../i18n';
import type { Lang } from '../i18n/config';
import { langPrefix } from '../i18n/config';

export interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  pageKey?: PageKey;
}

const { title, description, lang = 'fr', pageKey = 'home' } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const prefix = langPrefix(lang);

const nav = [
  { key: 'home' as PageKey, label: t.ui.nav.home, num: 'I' },
  { key: 'name' as PageKey, label: t.ui.nav.name, num: 'II' },
  { key: 'sardinia' as PageKey, label: t.ui.nav.sardinia, num: 'III' },
  { key: 'banditry' as PageKey, label: t.ui.nav.banditry, num: 'IV' },
  { key: 'anonima' as PageKey, label: t.ui.nav.anonima, num: 'V' },
  { key: 'genealogy' as PageKey, label: t.ui.nav.genealogy, num: 'VI' },
];

function pathFor(key: PageKey, targetLang: Lang = lang): string {
  const slug = pageSlugs[key][targetLang];
  const p = langPrefix(targetLang);
  if (!slug) return p === '' ? '/' : `${p}/`;
  return `${p}/${slug}/`;
}

const hreflangs: { lang: Lang; href: string }[] = [
  { lang: 'fr', href: pathFor(pageKey, 'fr') },
  { lang: 'it', href: pathFor(pageKey, 'it') },
  { lang: 'en', href: pathFor(pageKey, 'en') },
];

const desc = description ?? t.home.metaTitle;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={desc} />
  <meta name="theme-color" content="#1a150d" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {hreflangs.map(h => (
    <link rel="alternate" hreflang={h.lang} href={h.href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={pathFor(pageKey, 'fr')} />
  <title>{title}</title>
</head>
<body>

  <div class="bg-sardaigne-encre text-pierre-100 text-[0.68rem] tracking-widest uppercase py-2 relative z-10" style="letter-spacing:0.25em;">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      <span class="opacity-70">{t.ui.topbar}</span>
      <span class="hidden md:flex items-center gap-3 opacity-70">
        <span>Sardegna</span>
        <span class="text-sardaigne-rouge">✦</span>
        <span>Lorraine</span>
      </span>
    </div>
  </div>

  <header class="border-b border-sardaigne-encre/20 bg-sardaigne-parchemin/80 backdrop-blur-sm sticky top-0 z-20">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
      <a href={pathFor('home')} class="group flex items-center gap-3 shrink-0">
        <svg width="32" height="32" viewBox="0 0 32 32" class="transition-transform group-hover:rotate-6">
          <rect x="0" y="0" width="32" height="32" fill="#f1e8d4" stroke="#1f1a14" stroke-width="1"/>
          <line x1="16" y1="0" x2="16" y2="32" stroke="#9a1b1f" stroke-width="2.5"/>
          <line x1="0" y1="16" x2="32" y2="16" stroke="#9a1b1f" stroke-width="2.5"/>
          <circle cx="8" cy="8" r="2" fill="#1f1a14"/>
          <circle cx="24" cy="8" r="2" fill="#1f1a14"/>
          <circle cx="8" cy="24" r="2" fill="#1f1a14"/>
          <circle cx="24" cy="24" r="2" fill="#1f1a14"/>
        </svg>
        <div class="flex flex-col leading-none">
          <span class="font-display text-2xl text-sardaigne-encre">Porcu</span>
          <span class="eyebrow mt-1 text-[0.6rem]">{t.ui.siteSubtitle}</span>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        {nav.map((item) => {
          const href = pathFor(item.key);
          const isActive = currentPath === href || (item.key === 'home' && currentPath === prefix + '/') || (item.key === 'home' && currentPath === '/' && lang === 'fr');
          return (
            <a
              href={href}
              class={`group relative px-2.5 py-2 font-sans text-[0.78rem] tracking-wide transition-colors ${isActive ? 'text-sardaigne-rouge' : 'text-sardaigne-encre hover:text-sardaigne-rouge'}`}
            >
              <span class="text-[0.6rem] text-sardaigne-sepia mr-1.5 font-serif italic">{item.num}</span>
              {item.label}
              {isActive && (
                <span class="absolute bottom-0 left-2.5 right-2.5 h-[1px] bg-sardaigne-rouge"></span>
              )}
            </a>
          );
        })}
      </nav>

      <div class="hidden md:flex items-center gap-1 border-l border-sardaigne-encre/15 pl-4 ml-2">
        {(['fr', 'it', 'en'] as Lang[]).map(l => {
          const isCurrent = l === lang;
          return (
            <a
              href={pathFor(pageKey, l)}
              class={`font-sans text-[0.7rem] uppercase px-2 py-1 transition-colors ${isCurrent ? 'text-sardaigne-rouge font-semibold' : 'text-sardaigne-encre/60 hover:text-sardaigne-rouge'}`}
              style="letter-spacing:0.15em;"
              hreflang={l}
              aria-current={isCurrent ? 'true' : undefined}
            >{l}</a>
          );
        })}
      </div>

      <button id="burger" class="lg:hidden w-10 h-10 flex items-center justify-center" aria-label="Menu">
        <div class="w-6 h-[1px] bg-sardaigne-encre relative">
          <span class="absolute w-6 h-[1px] bg-sardaigne-encre -top-2 left-0"></span>
          <span class="absolute w-6 h-[1px] bg-sardaigne-encre top-2 left-0"></span>
        </div>
      </button>
    </div>

    <nav id="mobile-nav" class="hidden lg:hidden border-t border-sardaigne-encre/20">
      {nav.map((item) => {
        const href = pathFor(item.key);
        const isActive = currentPath === href;
        return (
          <a href={href} class={`block px-6 py-3 border-b border-sardaigne-encre/10 font-sans text-sm ${isActive ? 'text-sardaigne-rouge bg-sardaigne-parchemin' : 'text-sardaigne-encre'}`}>
            <span class="text-[0.65rem] text-sardaigne-sepia mr-2 font-serif italic">{item.num}</span>
            {item.label}
          </a>
        );
      })}
      <div class="flex justify-center gap-3 py-4 border-t border-sardaigne-encre/10">
        <span class="eyebrow text-sardaigne-sepia">{t.ui.langSwitcher} :</span>
        {(['fr', 'it', 'en'] as Lang[]).map(l => {
          const isCurrent = l === lang;
          return (
            <a
              href={pathFor(pageKey, l)}
              class={`font-sans text-xs uppercase ${isCurrent ? 'text-sardaigne-rouge font-semibold' : 'text-sardaigne-encre/60'}`}
              style="letter-spacing:0.15em;"
            >{l}</a>
          );
        })}
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="mt-32 border-t border-sardaigne-encre/20 bg-sardaigne-encre text-pierre-100">
    <div class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <div class="font-display text-3xl text-sardaigne-parchemin mb-3">Archivio Porcu</div>
        <p class="text-pierre-200 text-sm leading-relaxed max-w-md">
          {t.ui.footerEthical}
          <a href={pathFor('legalRemoval')} class="text-sardaigne-rouge hover:text-sardaigne-parchemin underline transition-colors"> {t.ui.footerEthicalLink}</a>.
        </p>
      </div>
      <div>
        <div class="eyebrow text-pierre-300 mb-4">{t.ui.footerSections}</div>
        <ul class="space-y-2 text-sm font-sans">
          {nav.slice(1).map((item) => (
            <li><a href={pathFor(item.key)} class="text-pierre-200 hover:text-sardaigne-parchemin">{item.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="eyebrow text-pierre-300 mb-4">{t.ui.footerSources}</div>
        <ul class="space-y-2 text-sm font-sans text-pierre-200">
          <li>Antenati · Archivi di Stato</li>
          <li>FamilySearch</li>
          <li>Geneanet</li>
          <li>Emeroteca Sarda</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-pierre-800">
      <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-sans text-pierre-300">
        <span>{t.ui.footerCopy}</span>
        <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
          <a href={pathFor('legalMentions')} class="hover:text-sardaigne-parchemin transition-colors">{t.ui.legalLinks.mentions}</a>
          <span class="text-pierre-700">·</span>
          <a href={pathFor('legalPrivacy')} class="hover:text-sardaigne-parchemin transition-colors">{t.ui.legalLinks.privacy}</a>
          <span class="text-pierre-700">·</span>
          <a href={pathFor('legalRemoval')} class="hover:text-sardaigne-parchemin transition-colors">{t.ui.legalLinks.removal}</a>
        </div>
        <span class="flex items-center gap-3">
          <span class="text-sardaigne-rouge">✦</span>
          <span>{t.ui.footerTagline}</span>
          <span class="text-sardaigne-rouge">✦</span>
        </span>
      </div>
    </div>
  </footer>

  <script>
    const burger = document.getElementById('burger');
    const mobileNav = document.getElementById('mobile-nav');
    burger?.addEventListener('click', () => mobileNav?.classList.toggle('hidden'));
  </script>

</body>
</html>
